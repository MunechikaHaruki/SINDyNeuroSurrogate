# --- Figure ---
figure.facecolor: white
savefig.format: png
figure.dpi: 80
# --- Font (Sans-serif) ---
font.family: sans-serif
font.size: 10
axes.labelsize: 12
xtick.labelsize: 10
ytick.labelsize: 10

# --- Lines & Markers ---
lines.linewidth: 1.5
lines.markersize: 10

# --- Axes & Grid ---
axes.linewidth: 2.5
axes.grid: True
grid.linewidth: 1.5
grid.linestyle: --
grid.alpha: 0.6

# --- Legend ---
legend.fontsize: 9
legend.frameon: True